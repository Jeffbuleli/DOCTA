// Docta — schema Prisma (socle)
// Multi-tenant (etablissement) + RBAC + bi-devise CDF/USD + patient de base.
// Les modules cliniques (hospitalisation, bloc, pharmacie...) viendront s'y greffer.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

/// Etablissement = locataire (tenant). Chaque donnee est rattachee a un tenant.
model Tenant {
  id        String   @id @default(cuid())
  name      String
  slug      String   @unique
  city      String?
  country   String   @default("CD") // RD Congo par defaut
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users         User[]
  patients      Patient[]
  exchangeRates ExchangeRate[]
  wards         Ward[]
}

enum Role {
  SUPERADMIN // exploitant de la plateforme
  ADMIN // directeur / medecin-chef
  DOCTOR
  NURSE
  RECEPTION
  CASHIER
  PHARMACIST
  LAB
  IMAGING
  LOGISTICS
  HR
}

model User {
  id           String   @id @default(cuid())
  tenantId     String
  email        String
  passwordHash String
  fullName     String
  role         Role     @default(RECEPTION)
  active       Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, email])
  @@index([tenantId])
}

enum Currency {
  CDF // Franc congolais
  USD // Dollar americain
}

/// Taux du jour : combien de CDF pour 1 USD (ex: 2800).
model ExchangeRate {
  id        String   @id @default(cuid())
  tenantId  String
  date      DateTime @default(now())
  cdfPerUsd Decimal  @db.Decimal(14, 4)
  createdAt DateTime @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId, date])
}

enum Sex {
  M
  F
}

/// Patient — identite de base (le dossier clinique complet viendra ensuite).
model Patient {
  id          String    @id @default(cuid())
  tenantId    String
  mrn         String // numero de dossier (Medical Record Number) interne
  firstName   String
  lastName    String
  sex         Sex?
  birthDate   DateTime?
  phone       String?
  address     String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  tenant     Tenant      @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  admissions Admission[]

  @@unique([tenantId, mrn])
  @@index([tenantId, lastName])
}

/// =====================  HOSPITALISATION  =====================

enum BedStatus {
  AVAILABLE
  OCCUPIED
  MAINTENANCE
}

enum AdmissionStatus {
  ACTIVE
  DISCHARGED
  TRANSFERRED
}

/// Service / unite d'hospitalisation (Medecine interne, Chirurgie, Maternite...)
model Ward {
  id        String   @id @default(cuid())
  tenantId  String
  name      String
  createdAt DateTime @default(now())

  tenant     Tenant      @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  rooms      Room[]
  admissions Admission[]

  @@index([tenantId])
}

/// Salle rattachee a un service.
model Room {
  id       String @id @default(cuid())
  tenantId String
  wardId   String
  name     String

  ward Ward  @relation(fields: [wardId], references: [id], onDelete: Cascade)
  beds Bed[]

  @@index([tenantId])
  @@index([wardId])
}

/// Lit dans une salle.
model Bed {
  id       String    @id @default(cuid())
  tenantId String
  roomId   String
  label    String
  status   BedStatus @default(AVAILABLE)

  room       Room        @relation(fields: [roomId], references: [id], onDelete: Cascade)
  admissions Admission[]

  @@index([tenantId])
  @@index([roomId])
}

/// Sejour d'un patient : admission -> (transfert) -> sortie.
model Admission {
  id           String          @id @default(cuid())
  tenantId     String
  patientId    String
  wardId       String
  bedId        String
  status       AdmissionStatus @default(ACTIVE)
  reason       String?
  admittedAt   DateTime        @default(now())
  dischargedAt DateTime?

  patient Patient @relation(fields: [patientId], references: [id], onDelete: Cascade)
  ward    Ward    @relation(fields: [wardId], references: [id])
  bed     Bed     @relation(fields: [bedId], references: [id])

  @@index([tenantId, status])
  @@index([patientId])
}
