# Copier en .env et adapter
# Postgres 16 local (EnterpriseDB) — adapter user/mot de passe/base
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/docta?schema=public"

# Secret JWT (changer en production)
JWT_SECRET="dev-secret-a-changer"
JWT_EXPIRES_IN="7d"

# Port de l'API
PORT=3000

# Origine autorisee pour le frontend (CORS)
WEB_ORIGIN="http://localhost:5173,http://localhost:5174"

# URL publique du portail patient (liens d'e-mail). Defaut: 1ere valeur de WEB_ORIGIN
APP_PUBLIC_URL="http://localhost:5174"

# E-mail (Resend) — laisser vide en dev : les liens sont journalises et renvoyes par l'API
RESEND_API_KEY=""
MAIL_FROM="Docta <onboarding@resend.dev>"
